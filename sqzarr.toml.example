# sqzarr.toml — SQZARR configuration
# Copy to /etc/sqzarr/sqzarr.toml and edit.

[server]
host = "127.0.0.1"   # change to 0.0.0.0 for Tailscale/LAN access
port = 8080
data_dir = "/var/lib/sqzarr"   # where sqzarr.db lives

[scanner]
interval_hours = 6            # how often to scan directories
worker_concurrency = 1        # parallel transcode workers (max 8; GPU usually handles 1)

[transcoder]
# temp_dir = "/tmp/sqzarr"     # where in-progress output files are written
                               # default: same directory as source file

[safety]
# Name of the subdirectory within each root dir where originals are held.
# A leading dot makes it hidden on Linux/macOS.
processed_dir_name = ".processed"

# Days before held originals are automatically deleted by the GC.
originals_retention_days = 10

# Number of transcode failures before a file is permanently excluded.
fail_threshold = 1

# Number of consecutive system-wide failures before the queue auto-pauses.
system_fail_threshold = 5

# Require confirmation before deleting a single original in the UI.
# Bulk deletes always confirm.
delete_confirm_single = false

[plex]
enabled = false
base_url = ""   # e.g. http://192.168.1.10:32400
token = ""      # X-Plex-Token — see README for how to obtain

[auth]
# Leave password_hash empty to disable authentication entirely.
# To set a password: run `sqzarr hash-password` and paste the output here.
password_hash = ""
jwt_secret = ""   # auto-generated on startup if empty (changing it logs everyone out)
